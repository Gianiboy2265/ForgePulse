{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ForgePulse",
  "version": "0.1.0",
  "identifier": "dev.forgepulse.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ForgePulse",
        "width": 1320,
        "height": 840,
        "minWidth": 820,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "ForgePulse contributors",
    "shortDescription": "Local-first Windows performance laboratory",
    "longDescription": "Evidence-based local PC monitoring, diagnostics, and reversible performance experiments.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
